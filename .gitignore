# Secrets — never commit
.env
credentials.json
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Exports / generated assets
exports/
*.png
*.jpg
*.jpeg

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Claude Code worktrees — never commit these
.claude/worktrees/
!assets/*.png

# Per-process data caches — regenerated each run
data/*_cache.json
data/experiment_backlog.json
data/experiment_directive.json

# Raw daily snapshots — the post-processed sentiment_callouts.json is the
# committed artifact; the per-day raw fetches under sentiment_raw/ are not.
data/sentiment_raw/

# Logs are never committed — they capture secrets in URLs/tracebacks (a Redash
# API key leaked via logs/weekly_feedback_loop/2026-04-27.log on a public repo).
# Ignore the whole tree; the previously-tracked logs/ files were untracked.
logs/
