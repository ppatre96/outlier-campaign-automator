# Outlier Campaign Agent — Example environment variables
# Copy to `.env` and fill in real values for your environment.
# (This file is checked into git; never commit secrets.)

# --- Meta Ads ---
# Outlier ad account creds (system user). Doppler dev/prd are the source of truth.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_179828021490349
META_API_VERSION=v21.0
# Outlier Facebook Page — required for image-ad creation (object_story_spec.page_id).
META_PAGE_ID=260786120451494
# Pixel + Custom Conversion (worker_skill_all). When both are set, ad sets
# optimize for OFFSITE_CONVERSIONS with a 7-day click attribution window.
# Clear both to fall back to LINK_CLICKS optimization.
META_PIXEL_ID=637714478283926
META_CUSTOM_CONVERSION_ID=986478843749388
META_ATTRIBUTION_WINDOW_DAYS=7
# Frequency cap on every prospecting ad set (3 impressions / 7 days). Set
# META_FREQUENCY_CAP_IMPRESSIONS=0 to disable.
META_FREQUENCY_CAP_IMPRESSIONS=3
META_FREQUENCY_CAP_INTERVAL_DAYS=7
# Override exclusion audience list (JSON array of audience IDs). When unset,
# the four "Actives - 12.12.24" audiences from config.py are excluded.
# META_EXCLUDE_AUDIENCE_IDS_JSON=["120211889244260257","120211112196180257","120211112198140257","120211112208060257"]
# Dual ad-set strategy (LAL primary + broad control). Takes effect once LAL
# Custom Audiences ship (feature #5). META_LAL_BUDGET_SPLIT_PCT is the share
# of cohort budget routed to the LAL ad set; broad control gets the rest.
META_BROAD_CONTROL_ENABLED=true
META_LAL_BUDGET_SPLIT_PCT=70

# --- Phase 2.5 V2: Sentiment Miner ---
# Thresholds (defaults OK for most use)
SENTIMENT_THEME_MIN_EVIDENCE=3
SENTIMENT_LOOKBACK_DAYS=7
SENTIMENT_REDDIT_SUBS=Outlier_AI,BeerMoney,WorkOnline

# Zendesk — leave blank to skip internal sentiment source
# Obtain: Zendesk Admin -> Apps and integrations -> APIs -> Zendesk API -> Token access
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=

# Intercom — leave blank to skip internal sentiment source
# Obtain: Intercom Developer Hub -> Workspace settings -> Access token (read-conversations + read-tickets scopes)
INTERCOM_ACCESS_TOKEN=
